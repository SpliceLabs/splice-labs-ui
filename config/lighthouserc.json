{
  "ci": {
    "collect": {
      "startServerCommand": "npm run start",
      "startServerReadyPattern": "Ready",
      "startServerReadyTimeout": 60000,
      "url": [
        "http://localhost:8080/",
        "http://localhost:8080/helios",
        "http://localhost:8080/blog/index-demo",
        "http://localhost:8080/blog/article-demo"
      ],
      "numberOfRuns": 5
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.99 }],
        "categories:accessibility": ["warn", { "minScore": 0.99 }],
        "categories:best-practices": ["warn", { "minScore": 0.99 }],
        "categories:seo": ["warn", { "minScore": 0.99 }],
        "largest-contentful-paint": ["warn", { "maxNumericValue": 1800 }],
        "cumulative-layout-shift": ["warn", { "maxNumericValue": 0.02 }],
        "total-blocking-time": ["warn", { "maxNumericValue": 80 }],
        "first-contentful-paint": ["warn", { "maxNumericValue": 1000 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
