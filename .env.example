# ===========================================
# Resend Email Configuration (Contact Form)
# ===========================================

# Required: Get your API key from https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Required: Email address that receives contact form submissions
CONTACT_TO_EMAIL=hello@splicelabs.xyz

# Required: Verified sender address (must use domain verified in Resend)
# See: https://resend.com/domains
CONTACT_FROM_EMAIL=hello@splicelabs.xyz

# Optional: CC recipients (comma-separated for multiple)
# CONTACT_CC_EMAIL=

# Optional: BCC recipients (comma-separated for multiple)
# CONTACT_BCC_EMAIL=

# ===========================================
# Slack Integration (Contact Form)
# ===========================================

# Optional: Slack bot token for contact notifications
# Create a Slack App at https://api.slack.com/apps
# Add chat:write scope, install to workspace, copy Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxxx

# Optional: Slack channel ID for contact form notifications
# Right-click channel → View channel details → Copy channel ID (starts with C)
SLACK_CONTACT_CHANNEL_ID=C0XXXXXXXXX
